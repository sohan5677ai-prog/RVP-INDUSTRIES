DATABASE_URL="postgresql://rvp:rvp@localhost:5432/rvp?schema=public"
# Prisma migrations need a direct (non-pooled) connection. Locally this is the
# same URL as DATABASE_URL; on Supabase, DATABASE_URL is the pooled connection
# string (port 6543, ?pgbouncer=true) and DIRECT_URL is the direct one (port 5432).
DIRECT_URL="postgresql://rvp:rvp@localhost:5432/rvp?schema=public"
PORT=4000
# REQUIRED. The server refuses to start without this. Use a long random string
# (32+ chars), e.g. `openssl rand -hex 32`. Never commit the real value.
JWT_SECRET="change-me-in-production"
# Comma-separated list of allowed frontend origins (no trailing slash), e.g.
# "https://your-app.vercel.app,https://app.yourdomain.com"
CLIENT_ORIGIN="http://localhost:5173"
# Google Gemini API key for AI invoice reading on Stock In (https://aistudio.google.com/apikey)
GEMINI_API_KEY=""

# --- File storage (Supabase Storage) ---
# Project URL and service_role key from Supabase Project Settings > API.
# The service_role key bypasses RLS - server-side only, never expose to the client.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
# Storage bucket for uploaded invoice/kata files. Create it as a public bucket
# (files are already served as unguessable capability URLs, same as before).
SUPABASE_STORAGE_BUCKET="invoices"

# --- Slack bot (Socket Mode) ---
# Set SLACK_ENABLED=true to start the Slack bot alongside the API server.
SLACK_ENABLED="false"
# Bot User OAuth token (xoxb-...) — scopes: chat:write, commands, files:read,
# app_mentions:read, channels:history (or im:history).
SLACK_BOT_TOKEN=""
# App-Level token (xapp-...) with the connections:write scope, for Socket Mode.
SLACK_APP_TOKEN=""
# Signing secret (unused in Socket Mode; optional).
SLACK_SIGNING_SECRET=""

# --- Tally → ERP sync ---
# Shared secret the office-PC agent presents to POST /api/tally/sync. Set the SAME
# value here (server) and in the agent's environment. Use a long random string.
TALLY_SYNC_TOKEN=""
# --- Agent-only (set these on the office PC where the agent + Tally run) ---
# Public URL of the deployed ERP the agent pushes vouchers to.
ERP_BASE_URL="http://localhost:4000"
# Tally gateway location (agent runs on the same PC, so localhost).
TALLY_HOST="127.0.0.1"
TALLY_PORT="9000"
# Leave blank to use Tally's currently active company.
TALLY_COMPANY=""
# How far back each poll re-reads the day book (days). The server dedupes by GUID.
TALLY_LOOKBACK_DAYS="7"
# Poll interval in seconds.
TALLY_SYNC_INTERVAL_SEC="120"

# --- Email (Resend) ---
# Get your API key at https://resend.com
RESEND_API_KEY=""
# Verified sender, e.g. "RVP Industries <invoices@mail.yourdomain.com>". Until a
# domain is verified in Resend, leave blank to use the test sender
# onboarding@resend.dev (only delivers to the Resend account owner's own email).
RESEND_FROM_EMAIL=""
