generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
  OWNER
  DEVELOPER
}

enum PartyType {
  SUPPLIER
  BUYER
  BOTH
}

enum POStatus {
  PENDING
  ARRIVED
  COMPLETED
  CANCELLED
}

enum SaleStatus {
  PENDING
  PARTIAL
  DISPATCHED
  DELIVERED
}

enum AllocationStatus {
  SOFT
  HARD
  BUMPED
}

// Products sold. Pappu depletes the black-seed pool; Husk depletes its derived
// (25%) availability; TPS (brokens) is revenue-only. Shell, Waste and the three
// pre-cleaner byproducts (Pre Cleaner Dust, Nalla Pokkulu, Nalla Chintapandu)
// all deplete the single shared 10% "Pre Cleaner Husk & Tamarind" pool. Shell is
// physically transferred to another location before sale, but that transfer is
// only a movement/cost record — it is NOT held as a separate valued silo.
enum SaleProduct {
  PAPPU
  HUSK
  WASTE
  TPS
  SHELL
  PRECLEANER_DUST
  NALLA_POKKULU
  NALLA_CHINTAPANDU
}

enum Commodity {
  BLACK_SEED
  PAPPU
  HUSK
  TAMARIND_SHELL
  TAMARIND_WASTE
  TPS_BROKENS
  PRECLEANER_DUST
  NALLA_POKKULU
  NALLA_CHINTAPANDU
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  password  String
  role      Role     @default(USER)
  // Slack member ID (e.g. "U0123ABCD") used to attribute Slack-driven actions to
  // this ERP user. Null until an admin links the account.
  slackUserId String? @unique
  createdAt DateTime @default(now())
}

model Party {
  id                String          @id @default(cuid())
  name              String
  type              PartyType       @default(SUPPLIER)
  phone             String?
  address           String?
  state             String?
  pincode           String?
  gstin             String?
  // Default delivery destination for this buyer (maps to a freight rate).
  destination       String?
  bankAccountNumber String?
  bankIfsc          String?
  bankName          String?
  commodities       Commodity[]
  createdAt         DateTime        @default(now())
  purchaseOrders    PurchaseOrder[]
  saleOrders        SaleOrder[]
  payments          Payment[]
  receipts          Receipt[]
  dustPurchases     DustPurchase[]
  tallyLedgerMaps   TallyLedgerMap[]
}

model Broker {
  id         String      @id @default(cuid())
  name       String
  phone      String?
  saleOrders SaleOrder[]
  payments   Payment[]
}

model PurchaseOrder {
  id            String   @id @default(cuid())
  poNumber      String?  @unique
  poDate        DateTime
  party         Party    @relation(fields: [partyId], references: [id])
  partyId       String
  pricePerKg    Decimal  @db.Decimal(12, 2) // approx
  // Whether pricePerKg is quoted at the supplier's location (BASE) or landed at
  // our location (DELIVERY). Some suppliers quote one, some the other.
  priceType     PriceType @default(DELIVERY)
  hasGst        Boolean  @default(false)
  gstAmount     Decimal  @default(0) @db.Decimal(14, 2)
  tonnageKg     Int // approx, in kg
  actualTonnageKg Int? // actual arrived weight in kg (set at stock-in)
  lorryCount    Int? // approx number of lorries ordered
  // Links all per-lorry POs created together from one order, so they can be
  // grouped back into a single logical order in the UI.
  poGroupId     String?
  status        POStatus @default(PENDING)
  expectedYieldPct Decimal @default(60) @db.Decimal(5, 2)
  createdBy     String
  createdAt     DateTime @default(now())
  stockIns      StockIn[]
  allocations   SaleAllocation[]
}

model StockIn {
  id              String        @id @default(cuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId String
  arrivalDate       DateTime
  lorryNumber       String
  invoiceNumber     String // invoice number (e.g. "69")
  rvpFirstWeightKg  Int      @default(0) // RVP weighbridge: loaded/gross weight
  rvpSecondWeightKg Int      @default(0) // RVP weighbridge: empty/tare weight
  rvpKataKg         Int // Net weight from our weighbridge (RVP Kata) = first - second
  billingWeightKg   Int // invoice tonnage
  partyKataKg       Int // party weighbridge
  invoiceFileUrl    String // uploaded invoice
  loadingLocation   String        @default("RVP")
  // Inward freight (₹) captured at arrival, only for BASE-priced POs (DELIVERY
  // already includes it). Carried into Purchase.freightCharge and capitalised.
  freightCharge     Decimal       @default(0) @db.Decimal(12, 2)
  // Ticked when the party arrived in their OWN vehicle (no third-party lorry).
  // At verification the lorry's ₹80/t hamali share — normally recovered from the
  // transporter — is instead deducted from the party's net payable.
  selfVehicle       Boolean       @default(false)
  createdAt         DateTime      @default(now())
  purchase          Purchase?
}

model Purchase {
  id             String              @id @default(cuid())
  stockIn        StockIn             @relation(fields: [stockInId], references: [id])
  stockInId      String              @unique
  netWeightKg    Int // StockIn.rvpKataKg
  hamaliRate     Decimal             @default(80) @db.Decimal(8, 2) // per tonne
  hamaliCharge   Decimal             @db.Decimal(12, 2) // computed
  kataFee        Decimal             @default(0) @db.Decimal(12, 2) // computed
  // Bag-cutting (pouring black seed into a process bunker). Only set when the
  // stock lands directly at the process; storage stock gets it on transfer.
  bunkerPlace      BunkerPlace?

  // Inward freight to bring BASE-priced stock to our location (capitalised into
  // the seed). DELIVERY-priced POs already include freight in the price → 0.
  freightCharge    Decimal            @default(0) @db.Decimal(12, 2)
  discountType   DiscountType?
  discountValue  Decimal             @default(0) @db.Decimal(12, 2)
  createdAt      DateTime            @default(now())
  verification   WeightVerification?
  payments       Payment[]
  processing     Processing?
}

model WeightVerification {
  id              String   @id @default(cuid())
  purchase        Purchase @relation(fields: [purchaseId], references: [id])
  purchaseId      String   @unique
  billingWeightKg Int
  partyKataKg     Int
  rvpKataKg       Int
  referenceKg     Int
  diffKg          Int
  exempt          Boolean
  finalWeightKg   Int
  pricePerKg      Decimal  @db.Decimal(12, 2)
  // Net balance payable to the supplier (already net of any self-vehicle hamali
  // and kata recovery below). Seed inventory value = totalAmount + selfVehicleHamali.
  totalAmount     Decimal  @db.Decimal(14, 2)
  // ₹ deducted from the party's payable because they used their own vehicle
  // (the lorry's ₹80/t hamali share). 0 for third-party lorries.
  selfVehicleHamali Decimal @default(0) @db.Decimal(12, 2)
  // ₹ deducted from the party's payable because they used their own vehicle
  // (the full weighbridge/kata fee, normally recovered from the transporter).
  // Recovering it lowers the seed's landed cost. 0 for third-party lorries.
  selfVehicleKata Decimal @default(0) @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
}

model Processing {
  id                  String      @id @default(cuid())
  // Optional link back to the verified Purchase this batch was milled from.
  // Nullable so standalone (manually-entered) processing runs remain valid.
  purchase            Purchase?   @relation(fields: [purchaseId], references: [id])
  purchaseId          String?     @unique
  blackWeightKg       Int // input weight processed in mill
  outTurnPct          Decimal     @default(60) @db.Decimal(5, 2)
  pappuWeightKg       Int // computed
  huskWeightKg        Int         @default(0) // 25% yield
  wasteWeightKg       Int         @default(0) // 10% yield
  lostWeightKg        Int         @default(0) // 5% negligible waste
  overheadElectricity Decimal     @default(0) @db.Decimal(12, 2)
  overheadWages       Decimal     @default(0) @db.Decimal(12, 2)
  overheadMaintenance Decimal     @default(0) @db.Decimal(12, 2)
  loadingLocation     String      @default("RVP")
  processDate         DateTime
}

model SaleOrder {
  id             String      @id @default(cuid())
  saleDate       DateTime
  product        SaleProduct @default(PAPPU)
  buyer          Party       @relation(fields: [buyerId], references: [id])
  buyerId        String
  broker         Broker?     @relation(fields: [brokerId], references: [id])
  brokerId       String?
  tonnageKg      Int // total weight ORDERED, per RVP kata (kg) — never overwritten
  ratePerKg      Decimal     @db.Decimal(12, 2)
  gstAmount      Decimal     @default(0) @db.Decimal(14, 2) // 5% IGST on weight × rate
  brokerageRatePerKg Decimal   @default(0) @db.Decimal(12, 2)
  // Delivery destination (Surat/Barshi/Nagar) and the outward freight we bear,
  // since pappu etc. is sold at a delivery price. Freight is our selling expense.
  destination    String?
  freightCharge  Decimal     @default(0) @db.Decimal(12, 2)
  // PENDING (nothing dispatched) → PARTIAL (some, remaining > 0) → DISPATCHED
  // (fully dispatched). The order itself is never DELIVERED; delivery is tracked
  // per dispatch (shipment).
  status         SaleStatus  @default(PENDING)
  marginOverride Boolean     @default(false)
  // Payment terms: number of credit days. The clock starts from each dispatch's
  // deliveredDate, so dueDate = dispatch.deliveredDate + dueDays.
  dueDays        Int?

  // Each physical dispatch (lorry) is a SaleDispatch billed against this order.
  dispatches     SaleDispatch[]
  allocations    SaleAllocation[]

  // --- Legacy columns (pre multi-dispatch). No longer written; kept so the
  // backfill migration can copy them into the first SaleDispatch row. ---
  receivedDate   DateTime?
  deliveredDate  DateTime?
  invoiceNumber  String?
  vehicleNumber  String?
  invoiceFileUrl String?
  kataFileUrl    String?
  buyerKataKg    Int?
  shortageKg     Int?
  creditNoteAmount Decimal?    @db.Decimal(12, 2)
  buyerKataFileUrl String?
  invoiceSeq     Int?
  invoiceFy      String?
  invoiceDate    DateTime?

  createdAt      DateTime    @default(now())
}

// A single physical dispatch (one lorry) shipped against a SaleOrder. Carries the
// actual kata weight, the sale's ledger posting, its own tax invoice, and the
// delivery + buyer-kata shortage settlement. An order may have many of these.
model SaleDispatch {
  id             String     @id @default(cuid())
  saleOrder      SaleOrder  @relation(fields: [saleOrderId], references: [id])
  saleOrderId    String
  dispatchDate   DateTime   @default(now())
  weightKg       Int // actual dispatched weight, per RVP kata (kg)
  internalWeightKg Int? // weight before kata (without moisture gain)
  gstAmount      Decimal    @default(0) @db.Decimal(14, 2) // 5% IGST on weight × rate
  freightCharge  Decimal    @default(0) @db.Decimal(12, 2)
  // DISPATCHED → DELIVERED.
  status         SaleStatus @default(DISPATCHED)
  vehicleNumber  String?
  kataFileUrl    String?

  // Delivery matching (buyer's kata slip captured at delivery).
  receivedDate     DateTime?
  deliveredDate    DateTime?
  buyerKataKg      Int?
  shortageKg       Int?
  internalWeightProfitAmount Decimal? @db.Decimal(12, 2)
  creditNoteAmount Decimal?  @db.Decimal(12, 2)
  buyerKataFileUrl String?
  tdsAmount        Decimal?  @db.Decimal(12, 2)

  // Generated tax invoice. Number = prefix/seq/FY; seq resets each financial year.
  invoiceNumber  String?
  invoiceSeq     Int?
  invoiceFy      String? // Indian financial year, e.g. "2026-27"
  invoiceDate    DateTime?

  // E-Invoice (IRN) details
  irn            String?
  irnAckNo       String?
  irnAckDate     DateTime?
  irnSignedQr    String?
  irnStatus      String?    // 'GENERATED', 'CANCELLED'
  irnCancelledDate DateTime?

  // E-Way Bill details
  ewbNumber      String?
  ewbDate        DateTime?
  ewbValidUpto   DateTime?
  ewbStatus      String?    // 'GENERATED', 'CANCELLED'
  ewbCancelledDate DateTime?
  ewbDistance    Int?       // approx transport distance (km) entered at EWB generation

  createdAt      DateTime   @default(now())

  receipts       Receipt[]

  @@index([saleOrderId])
  @@unique([invoiceFy, invoiceSeq])
}

model SaleAllocation {
  id              String           @id @default(cuid())
  saleOrder       SaleOrder        @relation(fields: [saleOrderId], references: [id])
  saleOrderId     String
  purchaseOrder   PurchaseOrder    @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId String
  allocatedWeight Int
  status          AllocationStatus @default(SOFT)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([saleOrderId])
  @@index([purchaseOrderId])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

// Tally-style account-group hierarchy. `nature` fixes the debit/credit sign
// convention; `statement` decides whether the group lands on the Balance Sheet
// or the Profit & Loss.
enum GroupNature {
  ASSETS
  LIABILITIES
  INCOME
  EXPENSES
}

enum StatementType {
  BALANCE_SHEET
  PROFIT_LOSS
}

enum DiscountType {
  WEIGHT
  PRICE
  AMOUNT
}

enum PriceType {
  BASE
  DELIVERY
}

// Which bunker the black seed is poured into at the process. Drives the
// bunker place (A or B).
enum BunkerPlace {
  A
  B
}

// Tally primary/sub groups, a self-referential tree (e.g. Current Assets →
// Stock-in-Hand). The nature + statement are inherited from the primary group.
model AccountGroup {
  id        String         @id @default(cuid())
  name      String         @unique
  parentId  String?
  parent    AccountGroup?  @relation("GroupTree", fields: [parentId], references: [id])
  children  AccountGroup[] @relation("GroupTree")
  nature    GroupNature
  statement StatementType
  sortOrder Int            @default(0)
  accounts  Account[]
}

model Account {
  id    String        @id @default(cuid())
  code  String        @unique
  name  String
  type  AccountType
  lines JournalLine[]

  // Tally classification + opening balance for Balance Sheet / P&L reporting.
  groupId        String?
  group          AccountGroup? @relation(fields: [groupId], references: [id])
  // Signed opening balance brought forward: +Dr (assets/expenses) / -Cr (liabilities/income).
  openingBalance Decimal       @default(0) @db.Decimal(14, 2)
  // Decommissioned heads kept for historical lines but hidden from the live chart.
  isDeprecated   Boolean       @default(false)
  sortOrder      Int           @default(0)
}

model JournalEntry {
  id          String        @id @default(cuid())
  date        DateTime
  reference   String?
  description String
  createdAt   DateTime      @default(now())
  lines       JournalLine[]
  payment     Payment?
  receipt     Receipt?
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  journalEntryId String
  account        Account      @relation(fields: [accountId], references: [id])
  accountId      String
  debit          Decimal      @db.Decimal(12, 2)
  credit         Decimal      @db.Decimal(12, 2)
  costCenter     String?
}

// Editable per-destination outward freight rates (₹/tonne), managed in Settings.
model FreightRate {
  id           String   @id @default(cuid())
  destination  String   @unique
  ratePerTonne Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt    DateTime @updatedAt
}

// Editable per-operation hamali (labour) rates (₹/tonne), managed in Settings.
// One row per operation key (BLACK_SEED_UNLOAD, PAPPU_LOADING, TRANSFER_FROM_STORAGE,
// HUSK_LOADING, TPS_LOADING, SHELL_TRANSFER). These drive the live costing — each
// controller fetches its headline rate and passes it into the calc functions.
model HamaliRate {
  id             String   @id @default(cuid())
  key            String   @unique
  label          String
  ratePerTonne   Decimal  @default(0) @db.Decimal(8, 2) // Total ₹/tonne charge
  lorryPerTonne  Decimal  @default(0) @db.Decimal(8, 2) // collected from the driver (off freight)
  marginPerTonne Decimal  @default(0) @db.Decimal(8, 2) // company P/L benefit (collect more than we pay the crew)
  isCustom       Boolean  @default(false) // user-added cost (vs the fixed operations); charged on every Pappu dispatch
  sortOrder      Int      @default(0)
  updatedAt      DateTime @updatedAt
}

// Manually-entered hamali costs that can't be derived from purchases or sales.
// Two kinds:
//   Per-bag charges (amount = bags × ratePerBag):
//     - BAG_CUTTING_NORMAL    — bag cutting at Place A (≈₹3/bag)
//     - BAG_CUTTING_DISTANCE  — bag cutting at Place B (≈₹6/bag)
//     - PAPPU_NET             — pappu netting/bagging (≈₹6/bag)
//   Flat amounts (amount entered directly, bags/ratePerBag null):
//     - DIESEL                — diesel/fuel cost borne for the crew
//     - MISC                  — any other charge given to the hamali crew
//     - PAID                  — cash actually disbursed to the crew (settles the payable)
// Charge entries post Dr Factory Labor 50020 / Cr Hamali payable 20200; PAID
// posts Dr Hamali payable 20200 / Cr Cash-in-Hand 10410.
enum ManualHamaliType {
  BAG_CUTTING_NORMAL
  BAG_CUTTING_DISTANCE
  PAPPU_NET
  DIESEL
  MISC
  PAID
}

model ManualHamaliCost {
  id         String           @id @default(cuid())
  date       DateTime
  type       ManualHamaliType
  bags       Int?
  ratePerBag Decimal?         @db.Decimal(8, 2)
  amount     Decimal          @db.Decimal(12, 2) // per-bag: bags × ratePerBag; flat: entered directly
  note       String?
  createdBy  String?
  createdAt  DateTime         @default(now())
}

// A periodic reconciliation checkpoint on the Hamali Report: crew dues have been
// cross-verified with the hamali crew through `asOfDate` (inclusive). Verify-only
// marker with no GL posting - the actual cash settlement is recorded separately
// as a PAID ManualHamaliCost. The Hamali view locks rows on/before the latest
// checkpoint and shows the period since as the current, still-to-verify window.
model HamaliVerification {
  id        String   @id @default(cuid())
  asOfDate  DateTime // verified through this date, inclusive
  crewTotal Decimal  @db.Decimal(12, 2) // snapshot of crew dues verified in this period
  note      String?
  createdBy String?
  createdAt DateTime @default(now())
}

// Single-row seller profile printed on generated tax invoices. Edited in Settings.
model CompanyProfile {
  id                String   @id @default("default")
  name              String   @default("RVP INDUSTRIES")
  address           String? // multi-line seller address
  gstin             String?
  stateName         String?
  stateCode         String? // GST state code, e.g. "37"
  pincode           String?
  contact           String?
  // Bank details printed in the invoice footer.
  bankAccountName   String?
  bankName          String?
  bankAccountNumber String?
  bankBranchIfsc    String?
  // Invoice number = invoicePrefix/seq/FY (e.g. RVP/01/2026-27).
  invoicePrefix     String   @default("RVP")
  // JSON print-layout config (paper size, margins, font, column widths).
  invoiceLayout     String?
  // Comma or newline separated list of company vehicles exempt from kata & hamali
  companyVehicles   String?
  // ₹ held back from each sale lorry freight until delivery, then paid to Surya
  // Roadlines once the kata slip is received (configurable; default ₹3000).
  freightRetentionPerTrip Decimal @default(3000) @db.Decimal(12, 2)
  // Standard annual bank-loan interest rate (%) used to capitalise the stock's
  // carrying cost on storage→process transfers. Editable in the Loans section.
  loanInterestRatePct     Decimal @default(0) @db.Decimal(6, 3)
  // Buffer percentage (e.g. 80) of expected yield allowed for soft allocation.
  bufferStockPct          Decimal @default(80) @db.Decimal(5, 2)

  // TaxPro GSP configuration
  taxproGspId             String?
  taxproGspSecret         String?
  taxproGstUser           String?
  taxproGstPass           String?
  taxproSandbox           Boolean  @default(true)

  updatedAt         DateTime @updatedAt
}

// User-defined per-kg production cost components (electricity, labour, etc.).
// Their sum is the production cost per kg added on top of the black-seed cost
// for pappu (drives the displayed cost, the 3% margin check, and COGS).
model ProductionCostComponent {
  id        String   @id @default(cuid())
  name      String
  ratePerKg Decimal  @default(0) @db.Decimal(12, 4)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// Per-product HSN/SAC code and invoice description, managed in Settings.
model ProductTaxInfo {
  id          String      @id @default(cuid())
  product     SaleProduct @unique
  hsn         String? // primary HSN/SAC (the GST-taxable code)
  hsnExempt   String? // alternate HSN for the GST-exempt (without-GST) variant, e.g. husk
  description String?
  gstRate     Decimal     @default(5) @db.Decimal(5, 2) // GST % for this commodity (e.g. 5, 12, 18)
  updatedAt   DateTime    @updatedAt
}

model SiloInventory {
  id         String   @id @default(cuid())
  itemType   String // "BLACK_SEED" | "WHITE_PAPPU" | "HUSK" | "WASTE"
  location   String // e.g. "RVP", "PGR COLD", "Murugan", "KNM Multi", "Finished Silo"
  weightKg   Int      @default(0)
  totalValue Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt  DateTime @updatedAt
}

// Movement of black seed from a storage location (Rampalli/Murugan/Multi) to the
// process. Each transfer incurs two hamali legs (storage loading + process
// unloading), and transfer transport at the destination bunker —
// all 100% company-borne and capitalised into the seed's value at the process.
model StockTransfer {
  id               String       @id @default(cuid())
  fromLocation     String
  toLocation       String       @default("RVP")
  weightKg         Int
  lorryNumber      String?
  transportCharge  Decimal      @default(0) @db.Decimal(12, 2)
  loadingHamali    Decimal      @default(0) @db.Decimal(12, 2) // storage-unload leg — no longer charged, always 0
  unloadingHamali  Decimal      @default(0) @db.Decimal(12, 2) // load + unload combined
  bunkerPlace      BunkerPlace?

  hamaliMargin     Decimal      @default(0) @db.Decimal(12, 2) // company profit — no longer applicable, always 0
  // Bank-loan carrying interest capitalised into the seed at the process:
  // seedCostMoved × rate% × interestDays/365, where interestDays runs from the
  // earliest open loan's drawdown date to the transfer date.
  interestCharge   Decimal      @default(0) @db.Decimal(12, 2)
  interestDays     Int          @default(0)
  interestRatePct  Decimal      @default(0) @db.Decimal(6, 3)
  seedCostMoved    Decimal      @default(0) @db.Decimal(12, 2) // seed value drawn from source, by price band (landed ex-GST), not MAP
  movedValue       Decimal      @default(0) @db.Decimal(12, 2) // seedCostMoved + capitalised transfer costs (hamali + transport)
  transferDate     DateTime
  createdAt        DateTime     @default(now())
}

enum LoanStatus {
  OPEN
  CLOSED
}

// A single bank-loan drawdown (~₹15 lakh) taken against the stored stock, from
// one bank at a single standard rate. Interest accrues on the outstanding
// balance from drawdownDate until repaid; the carrying cost is capitalised into
// black seed when it moves storage→process (StockTransfer.interestCharge).
model BankLoan {
  id              String          @id @default(cuid())
  name            String? // loan name
  personName      String? // person on whose name loan is taken
  loanRef         String? // bank loan/account reference
  bankName        String?
  location        String?
  principal       Decimal         @db.Decimal(14, 2)
  drawdownDate    DateTime
  interestRatePct Decimal         @db.Decimal(6, 3) // snapshot of the rate at drawdown
  status          LoanStatus      @default(OPEN)
  closedDate      DateTime?
  notes           String?
  createdAt       DateTime        @default(now())
  repayments      LoanRepayment[]
}

model LoanRepayment {
  id        String   @id @default(cuid())
  loan      BankLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  loanId    String
  amount    Decimal  @db.Decimal(14, 2)
  date      DateTime
  reference String?
  createdAt DateTime @default(now())
}

// Movement of tamarind shell (a production byproduct) from the factory/process
// to the Rampalli storage, where it is later sold. Each transfer bears packing +
// loading + unloading hamali (₹333/tonne) and a fixed ₹500 transport — both
// capitalised into the shell's value at Rampalli.
model ShellTransfer {
  id              String   @id @default(cuid())
  fromLocation    String   @default("RVP")
  toLocation      String   @default("PGR COLD")
  weightKg        Int
  lorryNumber     String?
  hamaliCharge    Decimal  @default(0) @db.Decimal(12, 2) // ₹333/t packing+loading+unloading
  transportCharge Decimal  @default(0) @db.Decimal(12, 2) // fixed ₹500
  totalCost       Decimal  @default(0) @db.Decimal(12, 2) // hamali + transport, capitalised at Rampalli
  transferDate    DateTime
  createdAt       DateTime @default(now())
}

// A transfer of husk (a milling byproduct) from the factory to one of our storage
// locations (PGR COLD / Murugan / KNM Multi). Like ShellTransfer this is only a
// physical-movement + cost record; the ₹333/t hamali and fixed ₹500 transport are
// expensed (see LedgerService.postHuskTransfer). Kept as its own model so husk
// transfers stay separate from the shell/dust transfer list.
model HuskTransfer {
  id              String   @id @default(cuid())
  fromLocation    String   @default("RVP")
  toLocation      String // PGR COLD | Murugan | KNM Multi
  weightKg        Int
  lorryNumber     String?
  hamaliCharge    Decimal  @default(0) @db.Decimal(12, 2) // ₹333/t packing+loading+unloading
  transportCharge Decimal  @default(0) @db.Decimal(12, 2) // fixed ₹500
  totalCost       Decimal  @default(0) @db.Decimal(12, 2) // hamali + transport
  transferDate    DateTime
  createdAt       DateTime @default(now())
}

// A purchase of pre-cleaner dust bought IN from an outside party (distinct from a
// ShellTransfer, which only moves our own byproduct to storage). It raises a
// supplier payable (Cr Accounts Payable) against a direct-expense cost
// (Dr Pre Cleaner Dust Purchases) - see LedgerService.postDustPurchase.
model DustPurchase {
  id             String   @id @default(cuid())
  party          Party    @relation(fields: [partyId], references: [id])
  partyId        String
  purchaseDate   DateTime
  weightKg       Int
  pricePerKg     Decimal  @db.Decimal(12, 2) // ₹ per kg
  amount         Decimal  @db.Decimal(14, 2) // pricePerKg × weightKg (payable to the party)
  lorryNumber    String?
  invoiceNumber  String?
  createdAt      DateTime @default(now())
}

model Payment {
  id             String        @id @default(cuid())
  date           DateTime
  amount         Decimal       @db.Decimal(12, 2)
  type           String        // 'SUPPLIER' | 'TRANSPORTER' | 'BROKER' | 'OTHER' | expense heads (DIESEL, HAMALI, ELECTRICITY, …) | 'DRAWINGS'
  partyId        String?
  party          Party?        @relation(fields: [partyId], references: [id])
  purchaseId     String?
  purchase       Purchase?     @relation(fields: [purchaseId], references: [id])
  brokerId       String?
  broker         Broker?       @relation(fields: [brokerId], references: [id])
  lorryNumber    String?
  payee          String?       // free-text recipient for expense/drawings payments (e.g. "Shabri Reddy")
  reference      String?
  description    String?
  journalEntryId String?       @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
}

model Receipt {
  id             String        @id @default(cuid())
  date           DateTime
  amount         Decimal       @db.Decimal(12, 2)
  tdsAmount      Decimal?      @db.Decimal(12, 2) // TDS deducted by buyer (0.1% of sale value)
  shortageAmount Decimal?      @db.Decimal(12, 2) // Kata / weight-shortage deduction
  type           String        // 'BUYER' | 'OTHER' | income heads (GUNNY_BAGS_SALE, SCRAP_SALE, HAMALI_INCOME, INTEREST_INCOME)
  partyId        String?
  party          Party?        @relation(fields: [partyId], references: [id])
  saleDispatchId String?
  saleDispatch   SaleDispatch? @relation(fields: [saleDispatchId], references: [id])
  payer          String?       // free-text payer for direct-income receipts (e.g. "gunny bag buyer")
  reference      String?
  description    String?
  journalEntryId String?       @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// Standalone byproduct-pool expense/record reports. These are NOT posted to the
// accounting ledger; they feed only the dashboard Husk (byproduct) P&L pool, each
// netting against the pooled husk/T-waste/TPS/byproduct revenue.
// ─────────────────────────────────────────────────────────────────────────────

enum GunnyBagDirection {
  PURCHASE
  SALE
}

// Gunny (bardana) bags bought or sold. Net cost fed to the husk pool =
// Σ PURCHASE.amount − Σ SALE.amount.
model GunnyBagEntry {
  id        String            @id @default(cuid())
  date      DateTime
  direction GunnyBagDirection
  quantity  Int // number of bags
  amount    Decimal           @db.Decimal(12, 2) // total ₹ for this entry
  note      String?
  createdAt DateTime          @default(now())
}

// Monthly electricity bill. `amount` (total bill) is the husk-pool expense; units
// & month are captured for reference.
model ElectricityBill {
  id        String   @id @default(cuid())
  date      DateTime
  month     String // billed month, e.g. "2026-07"
  units     Int      @default(0) // units consumed
  amount    Decimal  @db.Decimal(12, 2) // total bill ₹ (the expense)
  note      String?
  createdAt DateTime @default(now())
}

// Factory maintenance expense (QED AMC, repairs, etc.). Deducted from the pool.
model MaintenanceExpense {
  id          String   @id @default(cuid())
  date        DateTime
  description String // "QED AMC", "Factory repair", ...
  amount      Decimal  @db.Decimal(12, 2)
  note        String?
  createdAt   DateTime @default(now())
}

enum DrawingOwner {
  SHABRI
  REDDY
}

enum InterestType {
  CC
  TERM_LOAN
}

// Bank loan interest (cash-credit / term-loan) charged by the bank. Recorded from
// the Reports → Interest page and deducted from the husk pool as an operating cost.
model InterestCharge {
  id        String       @id @default(cuid())
  date      DateTime
  type      InterestType
  amount    Decimal      @db.Decimal(12, 2)
  note      String?
  createdAt DateTime     @default(now())
}

// Owner drawings (Shabri / Reddy). Deducted from the husk pool per owner request.
model Drawing {
  id        String       @id @default(cuid())
  date      DateTime
  owner     DrawingOwner
  amount    Decimal      @db.Decimal(12, 2)
  note      String?
  createdAt DateTime     @default(now())
}

// Resolves a Tally ledger name to an ERP Party. Built from the unmapped queue as
// the user confirms matches; consulted first by the importer before name-matching.
model TallyLedgerMap {
  id         String   @id @default(cuid())
  ledgerName String   @unique // exact Tally ledger name
  partyId    String?
  party      Party?   @relation(fields: [partyId], references: [id])
  note       String?
  createdAt  DateTime @default(now())
}

// Parking lot for Payment/Receipt vouchers whose counterparty ledger couldn't be
// matched to a Party. Surfaced in the UI for one-click manual mapping; never
// guessed onto the wrong party.
model TallyUnmappedVoucher {
  id            String   @id @default(cuid())
  tallyGuid     String   @unique
  voucherType   String // "Payment" | "Receipt"
  voucherNumber String?
  date          DateTime
  amount        Decimal  @db.Decimal(14, 2)
  ledgerName    String // the unmatched counterparty ledger
  narration     String?
  alterId       Int      @default(0)
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())
}
